# DS2 site — environment variables
# Copy to .env.local (gitignored) and fill in real values.
# Never commit real secrets to the repository.

# ── Supabase project ──────────────────────────────────────────────────────────
# Project URL — safe to expose (matches NEXT_PUBLIC_ prefix).
# Replace YOUR_PROJECT_REF with your actual Supabase project reference.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Anon/publishable key — safe to expose; all access is RLS-enforced.
# Get it from: Supabase dashboard → Project Settings → API → anon/public key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SERVICE ROLE KEY — SERVER ONLY. Never prefix with NEXT_PUBLIC_.
# Bypasses RLS; used exclusively server-side for the admin login
# username→account resolution. Get it from:
# Supabase dashboard → Project Settings → API → service_role key.
# DO NOT expose this in browser code or commit it anywhere.
SUPABASE_SERVICE_ROLE_KEY=

# ── Admin panel allowlist ─────────────────────────────────────────────────────
# Comma-separated list of email addresses permitted to access /admin.
# Both founders' emails; must match the auth.users accounts in Supabase.
ADMIN_ALLOWED_EMAILS=

# ── Contact → Telegram bridge ─────────────────────────────────────────────────
# With these unset the /api/contact route runs in dev mode: it logs messages
# server-side and the UI works fully, but nothing is delivered to Telegram.

# From @BotFather after /newbot
TELEGRAM_BOT_TOKEN=

# The group chat id (a negative number) for the group you + Stel share.
# Add the bot to the group, enable Topics, then read the id from
# https://api.telegram.org/bot<token>/getUpdates after posting once.
TELEGRAM_CHAT_ID=

# Random long string. Signs the per-visitor Telegram topic id so a client
# can't redirect messages into arbitrary topics. e.g. `openssl rand -hex 32`
CONTACT_SIGNING_SECRET=

# ── MegaGym client portal ─────────────────────────────────────────────────────
# JSON array of blocked client IDs (optional, defaults to []).
# MEGAGYM_BLOCKED=[]

# ── Xenia · AI receptionist (workspace) ───────────────────────────────────────
# Server-only. With it unset the /workspace/xenia chat surface returns an error;
# the engine package (@ds/xenia) is still demoable via its own `demo` script.
ANTHROPIC_API_KEY=

# Channels are stubbed in this pass — wire these when building them. Keep every
# one SERVER-ONLY (never NEXT_PUBLIC_); verify the provider signature on inbound.
# Telegram Bot API (a separate bot from the contact bridge above):
# XENIA_TELEGRAM_BOT_TOKEN=
# WhatsApp Cloud API (Meta):
# XENIA_WHATSAPP_PHONE_NUMBER_ID=
# XENIA_WHATSAPP_TOKEN=
# XENIA_WHATSAPP_VERIFY_TOKEN=
# XENIA_WHATSAPP_APP_SECRET=
# Phone voice (provider TBD — Vapi/Retell/Bland, or Twilio + STT/TTS):
# XENIA_VOICE_PROVIDER=
# XENIA_VOICE_API_KEY=

# ── Aegis · site audit (workspace) ────────────────────────────────────────────
# Aegis scans via Google PageSpeed Insights. Keyless works but is rate-limited
# (shared anonymous quota → 429s); set a key for reliable scans. Server-only.
# Get one free: Google Cloud console → enable "PageSpeed Insights API" → API key.
# PAGESPEED_API_KEY=
# The narrated read uses ANTHROPIC_API_KEY (above); without it Aegis runs scan-only.

# ── Plutus · collections (workspace) ──────────────────────────────────────────
# Reminder drafting uses ANTHROPIC_API_KEY (above); without it the cycle runs
# scan-only (chase list + queue, no drafted prose). Sending uses Resend over
# HTTPS — both unset means the approval flow uses a no-op stub (nothing leaves
# the building), so the whole loop is testable without a provider. Server-only.
# Get a key + verified sender at resend.com.
# RESEND_API_KEY=
# The verified From address reminders are sent from, e.g. "Acme <billing@acme.gr>".
# PLUTUS_EMAIL_FROM=

# ── Outreach · research engine (Peitho, /admin/outreach) ──────────────────────
# Research uses ANTHROPIC_API_KEY (above) + the Anthropic server-side web tools.
# Default profile is "lean" (60s-safe, web_search only). On Vercel Pro, set this to
# "true" to enable the "deep" profile (web_search + web_fetch, more searches) — and
# also raise the research route's maxDuration to 300.
# OUTREACH_RESEARCH_DEEP=true
# Phase 4 (email sender — not built yet): OUTREACH_EMAIL_FROM, OUTREACH_REPLY_TO (reuse RESEND_API_KEY).

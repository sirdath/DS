# Copy this to .env.local and fill in values. Never commit real keys.

# --- Anthropic (chatbot-core + research agents) ---
ANTHROPIC_API_KEY=

# --- OpenAI (embeddings for RAG, if used) ---
OPENAI_API_KEY=

# --- Supabase ---
# URL and anon key are safe to expose (RLS-enforced).
# Replace YOUR_PROJECT_REF with your actual Supabase project reference.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SERVICE ROLE KEY — SERVER ONLY. Never use NEXT_PUBLIC_ prefix. Bypasses RLS.
# Only used server-side for admin login username→account resolution.
SUPABASE_SERVICE_ROLE_KEY=

# --- Admin panel allowlist ---
# Comma-separated emails allowed to access /admin and /$ecretAnalytics.
ADMIN_ALLOWED_EMAILS=

# --- fal.ai (premium motion pipeline: Flux + Veo 3 + Kling) ---
FAL_KEY=

# --- Firecrawl (competitor + website research) ---
FIRECRAWL_API_KEY=

# --- Exa (optional semantic search) ---
EXA_API_KEY=

# --- 21st.dev Magic MCP ---
TWENTYFIRST_DEV_API_KEY=

# --- Xenia · AI receptionist channels (stubbed this pass; server-only) ---
# The engine uses ANTHROPIC_API_KEY above. Channel providers are wired later:
# XENIA_TELEGRAM_BOT_TOKEN=
# XENIA_WHATSAPP_PHONE_NUMBER_ID=
# XENIA_WHATSAPP_TOKEN=
# XENIA_WHATSAPP_VERIFY_TOKEN=
# XENIA_WHATSAPP_APP_SECRET=
# XENIA_VOICE_PROVIDER=
# XENIA_VOICE_API_KEY=
